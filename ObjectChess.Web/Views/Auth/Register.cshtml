@model ObjectChess.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="auth-container d-flex justify-content-center align-items-center" style="min-height: 80vh;">

    <div class="auth-card p-4 rounded shadow-lg" style="max-width: 400px; width: 100%; background-color: #222; border: 1px solid #333;">
        <h2 class="auth-title text-center text-white mb-1">Create Account</h2>
        <p class="auth-subtitle text-center mb-4" style="color: #aaa;">Join ObjectChess today</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="FullName" class="text-light mb-1">Full Name</label>
                <input asp-for="FullName" class="form-control" style="background-color: #1a1a1a; color: white; border: 1px solid #444;" placeholder="John Doe" required />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="text-light mb-1">Email Address</label>
                <input asp-for="Email" class="form-control" style="background-color: #1a1a1a; color: white; border: 1px solid #444;" placeholder="john@example.com" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="text-light mb-1">Password</label>
                <input asp-for="Password" class="form-control" style="background-color: #1a1a1a; color: white; border: 1px solid #444;" placeholder="Create a strong password" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ConfirmPassword" class="text-light mb-1">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" style="background-color: #1a1a1a; color: white; border: 1px solid #444;" placeholder="Repeat your password" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn w-100 mt-4 mb-2" style="background-color: #8cc63f; color: #222; font-weight: bold; padding: 12px;">Register</button>
        </form>

        <div class="auth-footer text-center mt-3" style="color: #aaa;">
            Already have an account? <a asp-action="Login" class="auth-link" style="color: #8cc63f; text-decoration: none;">Login here</a>
        </div>
    </div>
</div>
