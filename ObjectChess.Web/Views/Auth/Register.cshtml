@model ObjectChess.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">Create Account</h2>
        <p class="auth-subtitle">Join ObjectChess today</p>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="error-summary"></div>

            <div class="form-group">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="John Doe" required />
                <span asp-validation-for="FullName" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="john@example.com" required />
                <span asp-validation-for="Email" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" class="form-control" placeholder="Create a strong password" required />
                <span asp-validation-for="Password" class="error-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat your password" required />
                <span asp-validation-for="ConfirmPassword" class="error-text"></span>
            </div>

            <button type="submit" class="btn auth-btn">Register</button>
        </form>

        <div class="auth-footer">
            Already have an account? <a asp-action="Login" class="auth-link">Login here</a>
        </div>
    </div>
</div>