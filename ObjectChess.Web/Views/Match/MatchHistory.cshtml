@model ObjectChess.Web.ViewModels.MatchHistoryPageViewModel
@using ObjectChess.Web.ViewModels
@using ObjectChess.Business.Models

@{
    ViewData["Title"] = "Match History";
}

<link rel="stylesheet" href="~/css/MatchHistory.css" asp-append-version="true" />

<div class="header-container">
    <h2 class="page-title">Match History</h2>
    <button onclick="toggleForm()" class="btn btn-primary">
        + Add New Match
    </button>
</div>

<div id="addMatchForm" class="form-container @(ViewData.ModelState.IsValid ? "hidden" : "")">
    <form asp-action="AddMatch" method="post" class="match-form">
        
        <input type="text" asp-for="NewMatch.WhitePlayer" placeholder="White Player (Type 'Me' for yourself)" list="playerOptions" required />
        <input type="text" asp-for="NewMatch.BlackPlayer" placeholder="Black Player (Type 'Me' for yourself)" list="playerOptions" required />

        <datalist id="playerOptions">
            <option value="Me"></option>
        </datalist>

        <input type="text" asp-for="NewMatch.Winner" placeholder="Winner (Type 'Me', Name, or 'Draw')" list="winnerOptions" required />
        
        <datalist id="winnerOptions">
            <option value="Me"></option>
            <option value="Draw"></option>
        </datalist>

        <input type="datetime-local" asp-for="NewMatch.MatchDate" asp-format="{0:yyyy-MM-ddTHH:mm}" required />

        <textarea asp-for="NewMatch.RawMovesText" placeholder="Moves (Optional) e.g., e4 e5 Nf3 Nc6" rows="3" style="width: 100%; margin-bottom: 15px; padding: 10px; background-color: #222; color: #fff; border: 1px solid #444; border-radius: 4px; resize: vertical;"></textarea>
        <span asp-validation-for="NewMatch.RawMovesText" style="color: #ff4d4d; display: block; margin-bottom: 10px;"></span>

        <div class="form-actions">
            <button type="submit" class="btn btn-success">Save Match</button>
            <button type="button" onclick="toggleForm()" class="btn btn-secondary">Cancel</button>
        </div>
    </form>
</div>

<table class="match-table">
    <thead>
        <tr>
            <th>White Player</th>
            <th>Black Player</th>
            <th>Winner/Draw</th>
            <th>Match Date</th>
            <th class="action-column"></th> 
        </tr>
    </thead>
    <tbody>
        @foreach (MatchHistoryViewModel match in Model.Matches)
        {
            <tr class="match-row" onclick="toggleMoves('moves-@match.GameID')">
                <td>@match.WhitePlayer</td>
                <td>@match.BlackPlayer</td>
                <td>
                    @if (match.Winner == "Draw")
                    {
                        <span style="color: #aaa;">Draw</span>
                    }
                    else
                    {
                        <strong style="color: #aaa;">@match.Winner</strong>
                    }
                </td>
                <td style="color: #aaa;">@match.MatchDate.ToString("dd MMM yyyy - HH:mm")</td>
                <td class="action-cell" onclick="event.stopPropagation();">
                    <div style="display: flex; gap: 5px; justify-content: flex-end;">
                        <button type="button" class="btn btn-secondary btn-sm details-btn" onclick="toggleMoves('moves-@match.GameID')">Details</button>
                        <form asp-action="DeleteMatch" method="post" class="delete-form" onsubmit="return confirm('Are you sure you want to delete this match?');">
                            <input type="hidden" name="gameId" value="@match.GameID" />
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
            <tr id="moves-@match.GameID" class="moves-collapse-row hidden-moves">
                <td colspan="5" style="background-color: #1a1a1a; padding: 15px; border-bottom: 1px solid #333;">
                    <div style="color: #ddd;">
                        <strong style="color: #fff; display: block; margin-bottom: 8px;">Match Moves:</strong>
                        @if (match.Moves != null && match.Moves.Any())
                        {
                            <div style="display: flex; flex-wrap: wrap; gap: 10px; font-family: monospace; font-size: 14px;">
                                @for (int i = 0; i < match.Moves.Count; i++)
                                {
                                    MoveModel currentMove = match.Moves[i];
                                    if (i % 2 == 0)
                                    {
                                        <span style="color: #888; margin-right: -4px;">@(currentMove.MoveNumber).</span>
                                    }
                                    <span style="background-color: #2a2a2a; padding: 2px 6px; border-radius: 3px;">@currentMove.MoveText</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span style="color: #666; font-style: italic;">No moves recorded for this match.</span>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="pagination-container">
    @if (Model.TotalPages > 1)
    {
        <div class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-action="MatchHistory" 
                   asp-route-page="@i" 
                   class="btn @(i == Model.CurrentPage ? "active" : "")">
                    @i
                </a>
            }
        </div>
    }
</div>

<style>
    .match-row {
        cursor: pointer;
        transition: background-color 0.2s ease;
    }
    .match-row:hover {
        background-color: #252525 !important;
    }
    .match-row:hover .details-btn {
        opacity: 1;
    }
    .details-btn {
        opacity: 0.6;
        transition: opacity 0.2s ease;
    }
    .hidden-moves {
        display: none;
    }
    .btn-sm {
        padding: 4px 8px;
        font-size: 12px;
    }
</style>

<script>
    function toggleForm() {
        const form = document.getElementById("addMatchForm");
        form.classList.toggle("hidden");
    }

    function toggleMoves(rowId) {
        const row = document.getElementById(rowId);
        if (row) {
            row.classList.toggle("hidden-moves");
        }
    }
</script>